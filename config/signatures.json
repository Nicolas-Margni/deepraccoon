  "api_key_patterns": [
    {
      "pattern": "sk-[a-zA-Z0-9-]{20,}",
      "provider": "OpenAI",
      "severity": "CRITICAL"
    },
    {
      "pattern": "sk-ant-[a-zA-Z0-9-]{90,}",
      "provider": "Anthropic",
      "severity": "CRITICAL"
    },
    {
      "pattern": "AIza[a-zA-Z0-9_-]{35}",
      "provider": "Google",
      "severity": "CRITICAL"
    },
    {
      "pattern": "gsk_[a-zA-Z0-9]{52}",
      "provider": "Groq",
      "severity": "CRITICAL"
    },
    {
      "pattern": "Bearer [a-zA-Z0-9\\-._~+/]{40,}",
      "provider": "Generic Bearer Token",
      "severity": "HIGH"
    }
  ],
